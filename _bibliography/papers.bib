@article{gao2026pcman,
  abbr           = {ASOC},
  bibtex_show    = {true},
  title          = {Progressive Cross-Modal Attention Network for Brain--Computer Interface Decoding Using EEG and Functional Near-Infrared Spectroscopy (fNIRS)},
  author         = {Gao, Yunyuan and Luo, Xiaoqi and Zhang, Zhengnan and Shao, Xu and Qin, Yanhua},
  journal        = {Applied Soft Computing},
  volume         = {199C},
  pages          = {115318},
  year           = {2026},
  month          = {jun},
  publisher      = {Elsevier},
  doi            = {10.1016/j.asoc.2026.115318},
  url            = {https://doi.org/10.1016/j.asoc.2026.115318},
  html           = {https://doi.org/10.1016/j.asoc.2026.115318},
  abstract       = {Electroencephalography (EEG) offers millisecond-level temporal resolution but limited spatial localization, whereas functional near-infrared spectroscopy (fNIRS) provides better spatial resolution but shows a hemodynamic delay of several seconds. A hybrid EEG-fNIRS brain-computer interface fuses the complementary strengths of both modalities but faces challenges from intrinsic spatiotemporal heterogeneity between electrophysiological and hemodynamic signals. To address this, this study proposes a Progressive Cross-Modal Alignment Network (PCMAN), which achieves deep EEG-fNIRS fusion and alignment through a three-layer progressive mechanism: physical alignment (a Spatiotemporal correlation Dynamic Fusion framework, SDF), semantic alignment (a Multi-Dimensional Feature Enhancement Attention network, MDFEA), and task alignment (a Cross-modal Adaptive Decoding Network, CADN). On three cognitive tasks--mental arithmetic (MA), word generation (WG), and motor imagery (MI)--PCMAN achieved accuracies of 88.18%, 81.93%, and 72.94%, outperforming state-of-the-art hybrid BCI methods.},
  keywords       = {Hybrid brain-computer interface, EEG-fNIRS fusion, Cross-modal attention, Progressive alignment, Multimodal deep learning},
  pdf            = {pcman_asoc2026.pdf},
  preview        = {pcman.png},
  selected       = {true},
  additional_info = {. *SCI / JCR Q1 TOP*, IF≈6.6. Second author (student author). Framework: **PCMAN**.}
}

@article{lu2026neurosscl,
  abbr           = {Under Review},
  bibtex_show    = {true},
  title          = {Neuro-SSCL: A Neuro-Aware Semi-Supervised Contrastive Learning for Cross-Subject EEG Emotion Recognition},
  author         = {Lu, Jiangwen and Luo, Xiaoqi and Gao, Weixiang and Huang, Ruyue and Gao, Yunyuan},
  journal        = {IEEE Journal of Biomedical and Health Informatics (Under Review)},
  year           = {2026},
  abstract       = {Electroencephalography (EEG) has been widely used in emotion recognition, yet the scarcity of labeled samples remains a major obstacle to its broader application. Existing semi-supervised EEG-based emotion recognition methods mainly rely on data-driven distribution alignment strategies and have not fully explored the neurophysiological priors underlying affective neural activity. To address this issue, we propose a neuro-aware semi-supervised contrastive learning framework, termed Neuro-SSCL. It incorporates neuroscience-derived inductive biases into model design and optimization. Neurophysiological topology-aware soft contrastive learning (NT-SCL) explicitly integrates local spatial correlations induced by volume conduction and global functional connectivity topology into contrastive learning, while spectrum-adaptive guided multi-scale graph contrastive learning (SA-MGCL) enhances emotion-relevant spectral components and imposes multi-scale graph contrastive constraints. A semi-supervised multi-domain adaptation strategy further mitigates distribution shifts across labeled/unlabeled source and target domains via adversarial alignment. On SEED, SEED-IV and SEED-V under a semi-supervised cross-subject leave-one-subject-out protocol, Neuro-SSCL consistently outperforms state-of-the-art methods under different incomplete-label conditions.},
  keywords       = {EEG, emotion recognition, contrastive learning, semi-supervised learning, neuroscience},
  selected       = {true},
  additional_info = {. *Under Review* (Initial Submission) at IEEE Journal of Biomedical and Health Informatics. Second author (student author). Framework: **Neuro-SSCL**.}
}

@article{wu2026aglrtd,
  abbr           = {Under Review},
  bibtex_show    = {true},
  title          = {Attention-Guided Low-Rank Tensor Decomposition for Feature Analysis of MI-EEG Signals},
  author         = {Wu, Xiao and Gao, Weixiang and Luo, Xiaoqi and Zhang, Zhengnan and Gao, Yunyuan},
  journal        = {IEEE Transactions on Emerging Topics in Computational Intelligence (Under Review)},
  year           = {2026},
  abstract       = {Motor imagery electroencephalography (MI-EEG) decoding remains challenging because EEG signals are weak, nonstationary, and strongly coupled across spatial, temporal, and spectral domains. Tensor decomposition is effective for high-dimensional feature mining, but conventional EEG tensor decomposition methods often overlook physiological characteristics and impose task-agnostic low-rank constraints. This paper proposes an attention-guided low-rank tensor decomposition (AG-LRTD) framework for MI-EEG feature analysis and classification. MI-EEG signals are organized as four-order tensors (channel, temporal, frequency-band, and trial modes) to preserve multi-dimensional spatial-temporal-spectral structure. A convolutional attention module is embedded into a tensor-product-based low-rank decomposition to enhance task-relevant spatial patterns; tensor-product factorization with a tubal-rank constraint performs structured dimensionality reduction and noise suppression, while residual-dense-block-based implicit regularization mitigates the limitation of a single low-rank prior for nonstationary EEG. On three public MI-EEG datasets under a subject-dependent binary protocol, AG-LRTD achieves 95.83%, 94.72%, and 90.07% on Dataset 1, Dataset 4a, and the binary left/right subset of Dataset 2a, respectively, while retaining an interpretable tensor-structured modeling process.},
  keywords       = {Motor imagery EEG, brain-computer interface, attention mechanism, low-rank tensor decomposition, EEG classification},
  selected       = {false},
  additional_info = {. *Under Review* (Initial Submission) at IEEE Transactions on Emerging Topics in Computational Intelligence. Third author. Framework: **AG-LRTD**.}
}

@article{gao2026physiosync,
  abbr           = {Under Review},
  bibtex_show    = {true},
  title          = {Neurovascular Alignment and Reliability-Aware Fusion for Continuous EEG--fNIRS Emotion Regression},
  author         = {Gao, Yunyuan and Luo, Xiaoqi and Zhang, Zhengnan and Lu, Jiangwen and Zhang, Yingchun and Huang, Ruyue},
  journal        = {IEEE Transactions on Affective Computing (Under Review, Major Revision R1)},
  year           = {2026},
  abstract       = {Continuous affect tracking is central to closed-loop affective brain--computer interfaces and adaptive human--computer interaction. Continuous EEG--fNIRS regression is well suited to this setting because EEG captures rapid neural dynamics and fNIRS provides complementary hemodynamic information, but direct fusion often underperforms EEG-only baselines when neurovascular coupling (NVC) introduces subject- and region-dependent delays. PhysioSync addresses this by performing HRF-like temporal alignment and residual-aware reliability control before multimodal fusion. A learnable dual-gamma kernel maps EEG-derived drive to the fNIRS timeline through finite-window causal convolution, and the resulting residuals modulate the contribution of hemodynamic evidence during fusion. A linear-complexity Mamba encoder provides long-context EEG representation. On the 32-subject REFED within-subject 3-fold benchmark, PhysioSync reduces Avg MAE by 6.1% relative to the best fusion baseline and by 7.5% relative to EEG-only, while showing reduced error growth in 1--3 s trajectory forecasting.},
  keywords       = {physiological affect recognition, EEG--fNIRS fusion, continuous emotion regression, neurovascular coupling, multimodal affective BCI},
  preview        = {physiosync.png},
  selected       = {true},
  additional_info = {. *Under Review* (Major Revision, R1) at IEEE Transactions on Affective Computing. Second author (student author). Framework: **PhysioSync**.}
}
